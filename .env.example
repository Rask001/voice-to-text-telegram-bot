TELEGRAM_BOT_TOKEN=123456:replace_me
OPENAI_API_KEY=sk-replace_me

# ENV_FILE chooses which file to load, for example:
# ENV_FILE=.env.local python -m app.main
# APP_ENV is used only for startup logs and safety checks.
APP_ENV=production

# Defaults are suitable for production/local MVP; override later if needed.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TEXT_MODEL=gpt-5-mini
DATABASE_URL=sqlite:///data/bot.db
DAILY_VOICE_LIMIT=5
MAX_VOICE_SECONDS=900
DEFAULT_RESPONSE_MODE=short
OWNER_TELEGRAM_ID=
UNLIMITED_USER_IDS=
