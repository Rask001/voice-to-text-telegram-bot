TELEGRAM_BOT_TOKEN=123456:replace_me
OPENAI_API_KEY=sk-replace_me

# ENV_FILE chooses which file to load, for example:
# ENV_FILE=.env.local python -m app.main
# APP_ENV is used only for startup logs and safety checks.
APP_ENV=production

# Defaults are suitable for production/local MVP; override later if needed.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DATABASE_URL=sqlite:///data/bot.db
DAILY_VOICE_LIMIT=5
MAX_VOICE_SECONDS=900
DEFAULT_RESPONSE_MODE=short
DEFAULT_TIMEZONE=Russia/Moscow
DEFAULT_REMINDER_TIME=10:00
OWNER_TELEGRAM_ID=
UNLIMITED_USER_IDS=

# Telegram Stars MVP uses currency XTR and does not require a provider token.
# Prices are configured in app/payment_service.py.
